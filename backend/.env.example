# ─── قاعدة البيانات (مطلوب) ───────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/adwat_altajer

# ─── المصادقة (مطلوب) ─────────────────────────────────────────────────────
# سلسلة عشوائية طويلة (32 حرفًا فأكثر) — غيّرها في الإنتاج
JWT_SECRET=change_this_to_a_long_random_string_minimum_32_chars

# ─── مزوّدو الذكاء الاصطناعي ───────────────────────────────────────────────
# Gemini 2.5 Flash هو الأساسي (نصوص + رؤية + توليد صور) — مطلوب
GEMINI_API_KEY=AIza...
# Groq Llama — احتياطي عند فشل Gemini (اختياري لكن موصى به)
GROQ_API_KEY=gsk_...
# بروكسي سكني — ضروري على السيرفر لتجاوز حجب المتاجر (سلة/Cloudflare) لعناوين مراكز البيانات
# الصيغة: http://user:pass@gateway.provider.com:port  (اتركه فارغًا للتشغيل المحلي)
PROXY_URL=
# Claude — متاح لكنه معطّل من المسار حاليًا (اختياري؛ لعرض الحالة فقط)
ANTHROPIC_API_KEY=sk-ant-...
# تجاوز أسماء الموديلات (اختياري — لها قيم افتراضية في الكود)
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# ─── المتصفّح (Puppeteer) — مطلوب لمحلّل المتجر وتقارير PDF ولقطات الشاشة ───
# مسار Chrome/Chromium على الخادم
CHROME_PATH=C:/Program Files/Google/Chrome/Application/chrome.exe

# ─── Google PageSpeed — لفحص الأداء (Core Web Vitals) بدقّة (اختياري) ──────
# بدونه يعمل الفحص لكن قد يُحدّ من جوجل (rate limit)
PAGESPEED_API_KEY=AIza...

# ─── البريد (SMTP) — مطلوب لاستعادة كلمة المرور والتقارير الأسبوعية ────────
# بدون SMTP_USER تُتخطّى الرسائل بأمان (لا تتعطّل الخدمة)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@email.com
SMTP_PASS=your_app_password

# ─── Google Analytics (تكامل الأداء) — اختياري ───────────────────────────
# إمّا مسار ملف الاعتماد:
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/credentials.json
# أو محتوى JSON مباشرة:
# GA_CREDENTIALS_JSON={"type":"service_account",...}

# ─── النسخ الاحتياطي لقاعدة البيانات (يومي 4 صباحاً + npm run backup) ──────
# مسار pg_dump (يُكتشف تلقائياً على ويندوز؛ اضبطه لو لم يُوجد)
PG_DUMP_PATH=C:/Program Files/PostgreSQL/17/bin/pg_dump.exe
BACKUP_DIR=./backups
BACKUP_KEEP_DAYS=14
# أمر رفع سحابي اختياري — {file} يُستبدل بمسار النسخة (مثال أدناه لـ rclone/aws)
# BACKUP_UPLOAD_CMD=rclone copy "{file}" remote:adwat-backups
# BACKUP_UPLOAD_CMD=aws s3 cp "{file}" s3://your-bucket/backups/

# ─── مراقبة الأخطاء ───────────────────────────────────────────────────────
# بريد المسؤول لتلقّي تنبيهات الأعطال (يفترض SMTP مفعّل؛ يرجع لـ SMTP_USER)
ALERT_EMAIL=admin@email.com
# Sentry اختياري — فعّله بتثبيت @sentry/node ووضع الـDSN
# SENTRY_DSN=https://...@sentry.io/...

# ─── الخادم ───────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
# رابط الواجهة (لإعداد CORS في الإنتاج)
FRONTEND_URL=http://localhost:5500

# Google Analytics — زيارات المنصة في لوحة التحكم
# Property ID رقمي من GA4 (Admin → Property Settings)
GA_PLATFORM_PROPERTY=
# محتوى ملف حساب الخدمة JSON (سطر واحد)
GA_CREDENTIALS_JSON=
